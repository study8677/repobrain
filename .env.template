# -----------------------------
# ROOT — MCP servers (optional; used by `mcp_servers.json`)
# -----------------------------
MCP_ENABLED=false
GITHUB_TOKEN=
DATABASE_URL=
BRAVE_API_KEY=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# -----------------------------
# CORE vs TENANT — host boundary (anti-contamination)
# -----------------------------
# **CORE** = factory / ops surface (provision, master console, health). Put this on a dedicated
# hostname, e.g. core.corpflowai.com — listed here so we NEVER derive a client tenant_id from the
# first DNS label (avoids subdomain "core" becoming tenant_id "core").
# Comma-separated hostnames, no protocol; matches Host / X-Forwarded-Host (port stripped).
# Example:
CORPFLOW_CORE_HOSTS=core.corpflowai.com
#
# **Public marketing site** = its own tenant row in `tenants` (e.g. tenant_id `corpflowai`).
# Map apex hostname explicitly. Login + /api/tenant/site require that tenant id to exist in DB:
# CORPFLOW_TENANT_HOST_MAP={"corpflowai.com":"corpflowai"}
# Create the row via tenant-onboard / factory tools, then map the host in tenant_hostnames if needed.
#
# Apex (`CORPFLOW_ROOT_DOMAIN` exact host, e.g. corpflowai.com) ignores `tenant_hostnames` Postgres
# rows by default so a mistaken mapping cannot paint another client (e.g. luxe-maurice) on the apex.
# Set true only if you intentionally apex-map via DB:
# CORPFLOW_APEX_ALLOW_DB_HOST_OVERRIDE=false
#
# Fallback when apex host is not in the map (legacy / dev only):
CORPFLOW_DEFAULT_TENANT_ID=root
#
# Optional prefix for `{slug}.CORPFLOW_ROOT_DOMAIN` derivation (usually empty).
# CORPFLOW_TENANT_SLUG_PREFIX=
#
# Apex / regional root for subdomain routing (default matches production).
CORPFLOW_ROOT_DOMAIN=corpflowai.com
#
# Onboarding hostname policy: new client host maps should use *.CORPFLOW_ROOT_DOMAIN until DNS cutover.
# When true, POST /api/factory/host-map/upsert, CMP tenant-hostname-upsert, and tenant bootstrap reject
# hostnames that are not on-stack (subdomain of CORPFLOW_ROOT_DOMAIN) unless exempt (localhost, *.vercel.app, etc.)
# or listed in CORPFLOW_TENANT_HOSTNAME_ONBOARDING_EXEMPT. Custom domains after go-live: Change Console ticket, not the wizard.
# CORPFLOW_ENFORCE_CORPFLOW_SUBDOMAIN_ONBOARDING=true
#
# When true, on-stack hostnames must match the workspace id as the DNS prefix: {tenant_id}.CORPFLOW_ROOT_DOMAIN
# (e.g. acme-corp.corpflowai.com for tenant_id acme-corp). Legacy aliases (different prefix) → EXEMPT list or bypass.
# CORPFLOW_ENFORCE_HOSTNAME_MATCHES_TENANT_ID=true
#
# Extra hostnames allowed during enforced onboarding (comma-separated, no protocol), e.g. legacy client.com.
# CORPFLOW_TENANT_HOSTNAME_ONBOARDING_EXEMPT=
#
# Comma-separated tenant_id values that use neutral CorpFlow marketing defaults (not the Lux demo skin)
# in /api/tenant/site when no website_draft is saved — e.g. your own apex org tenant.
CORPFLOW_ORG_TENANT_IDS=corpflowai,root

# -----------------------------
# TENANT — Example mappings
# -----------------------------
# Tenant project IDs (workspace identifiers) — extend as you onboard more clients.
TENANT_LUXE_MAURICE_PROJECT_ID=LX-001
TENANT_LUXE_MAURICE_NOTIFICATION_ID=

