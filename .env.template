# CorpFlow AI Command Center — Environment Template
#
# IMPORTANT:
# - This file is a template only. Do NOT commit real secrets.
# - Copy to `.env` locally (or set equivalent variables in your Codespace/CI).
#
# Optional single-blob config in Vercel: CORPFLOW_RUNTIME_CONFIG_JSON must be **strict JSON**
# (double quotes, no trailing commas, no comments). UTF-8 BOM is stripped at runtime.
# Invalid JSON fails closed: critical keys will read as missing until fixed.
#
# Keys resolved via cfg() (individual env var OR same key inside the JSON blob):
#   N8N_WEBHOOK_URL, N8N_CMP_WEBHOOK_URL, CMP_GITHUB_TOKEN, GH_WORKFLOW_TOKEN,
#   GITHUB_REPO, CMP_GITHUB_REPOSITORY, CMP_SANDBOX_BASE_REF
#
# ROOT access = general Factory infrastructure.
# TENANT access = per-client workspace IDs / routing identifiers.

# -----------------------------
# ROOT — LLM / AI
# -----------------------------
GOOGLE_API_KEY=
GEMINI_MODEL_NAME=gemini-1.5-pro

# OpenAI-compatible backend (optional)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (Change Console, optional tenant chat, Technical Lead rephrase)
GROQ_API_KEY=
# Primary model (OpenAI-compatible chat/completions); empty uses built-in default in lib/server/groq-client.js
GROQ_MODEL_NAME=

PROVISIONING_ENABLED=false

# -----------------------------
# ROOT — n8n / workflow webhooks
# -----------------------------
# Lead intake (`/api/main` POST → JSON forwarded here)
N8N_WEBHOOK_URL=https://YOUR_N8N_HOST/webhook/leads

# Optional: notify n8n when CMP sandbox GitHub dispatch runs (approve-build / sandbox-start)
N8N_CMP_WEBHOOK_URL=

# -----------------------------
# ROOT — GitHub (CMP sandbox branch automation)
# -----------------------------
# Canonical variable — single source of truth:
# Repository as owner/name (used with repository_dispatch from Vercel)
#
# Prefer setting CMP_GITHUB_REPOSITORY for CMP so both core + tenant surfaces
# always dispatch to the same repo explicitly.
CMP_GITHUB_REPOSITORY=
GITHUB_REPO=

# Fine-grained or classic PAT with contents:write on this repo (store only in Vercel / secrets)
CMP_GITHUB_TOKEN=

# Optional alias for CMP_GITHUB_TOKEN (same cfg()/blob resolution)
GH_WORKFLOW_TOKEN=

# Optional: default base ref for sandbox branches
CMP_SANDBOX_BASE_REF=main

# -----------------------------
# ROOT — Telegram / Alerts
# -----------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# Optional: ops alert routing (n8n). If set, cmp-monitor will forward “blocked” alerts here.
CORPFLOW_AUTOMATION_FORWARD_URL=
CORPFLOW_AUTOMATION_FORWARD_SECRET=

# -----------------------------
# ROOT — Dormant Gate (production security)
# -----------------------------
# Enable to hide CMP bubble until an admin SESSION_TOKEN is verified.
DORMANT_GATE_ENABLED=true

# Master secret used to verify SESSION_TOKEN for admin unlocking.
# (In this template we use direct equality; in production prefer a hash.)
# Canonical variable — single source of truth:
MASTER_ADMIN_KEY=

# Optional alias for MASTER_ADMIN_KEY (Vercel Secret). Client sends the same value as x-session-token.
ADMIN_PIN=

# Optional OR-override with DB tenant_personas.billing_exempt (prefer setting billing_exempt in DB for scale).
# Comma-separated tenant ids: same as billing_exempt=true — no token gate/debit on approve-build; $0 client line on estimates.
CORPFLOW_BILLING_EXEMPT_TENANT_IDS=

# Try Me: starting wallet (USD) when a NEW `tenant_personas` row is first created.
# - Set CORPFLOW_TRY_ME_TENANT_IDS=id1,id2 to limit which tenants get the grant, OR
# - Set CORPFLOW_TRY_ME_ALL_NEW=true to grant CORPFLOW_TRY_ME_CREDITS_USD to every new persona row (use carefully).
CORPFLOW_TRY_ME_CREDITS_USD=
CORPFLOW_TRY_ME_TENANT_IDS=
CORPFLOW_TRY_ME_ALL_NEW=false

# Default wallet when no persona file / row (see lib/factory/costing.js).
DEFAULT_TOKEN_CREDIT_BALANCE_USD=0

# CorpFlow client price as a fraction of the traditional benchmark (full_market_value_usd). Default 0.1 = 10%.
# Clamped to [0.01, 1]. Approve-build wallet debit uses this line (displayed_client_usd), not the full benchmark.
CORPFLOW_CLIENT_BUILD_PRICE_RATIO=0.1

# Change Console file uploads (Postgres cmp_ticket_attachments; run factory ensure-schema + Prisma).
# Max file size (bytes, default 3MB). Max attachments per ticket. Allowed MIME: comma-separated prefixes or exact types.
CORPFLOW_CHANGE_UPLOAD_MAX_BYTES=3145728
CORPFLOW_CHANGE_UPLOAD_MAX_FILES_PER_TICKET=8
CORPFLOW_CHANGE_UPLOAD_ALLOWED_MIME=image/,video/,application/pdf

# -----------------------------
# ROOT — Web login (recommended)
# -----------------------------
# Required for HttpOnly session cookies (CMP + tenant login). See docs/operations/TENANT_CLIENT_LOGIN.md
SOVEREIGN_SESSION_SECRET=

# Admin login (factory-only). Once you login at /login, you get a secure HttpOnly cookie
# and never paste MASTER_ADMIN_KEY into pages again.
CORPFLOW_ADMIN_USERNAME=

# Easiest (plaintext) option: store in Vercel secrets. Optional: use *_HASH + *_SALT instead.
CORPFLOW_ADMIN_PASSWORD=
CORPFLOW_ADMIN_PASSWORD_SALT=
CORPFLOW_ADMIN_PASSWORD_HASH=

# Session cookie TTL (seconds). Default 43200 (12h). Min 600, max 86400.
CORPFLOW_SESSION_TTL_SEC=43200

# -----------------------------
# ROOT — Tenant password reset (optional)
# -----------------------------
# Password reset uses Postgres `recovery_vault_entries` to store one-time tokens.
#
# Delivery (pick one or both):
# 1) n8n email webhook — POST JSON to an n8n Webhook → Gmail (or other ESP) workflow.
#    Body includes: purpose, tenant_id, to, from, reset_url, reset_code (= token),
#    expires_at, expires_minutes, subject, plus legacy fields (event, email, token, reset_path,
#    public_base_url) for older workflows. See docs/n8n/password-reset-email-recipe.md.
N8N_EMAIL_WEBHOOK_URL=
# Shared secret; sent as header x-corpflow-email-secret (validate in n8n's first node).
N8N_EMAIL_WEBHOOK_SECRET=
# Default From hint for the n8n Gmail node (e.g. support@corpflowai.com). The Gmail node still
# enforces the actual alias on send; this value is the workflow input.
EMAIL_FROM=support@corpflowai.com
#
# Legacy aliases (kept for backwards compatibility — set EITHER pair, not both):
CORPFLOW_PASSWORD_RESET_WEBHOOK_URL=
CORPFLOW_PASSWORD_RESET_WEBHOOK_SECRET=
#
# 2) Resend — direct transactional email (https://resend.com). Verify your sending domain in Resend.
CORPFLOW_PASSWORD_RESET_RESEND_API_KEY=
CORPFLOW_PASSWORD_RESET_FROM_EMAIL=
#
# Public site URL for links in emails (e.g. https://lux.corpflowai.com). If unset, derived from request Host.
CORPFLOW_PUBLIC_BASE_URL=
# Token expiry in minutes (default 30, min 5, max 180)
CORPFLOW_PASSWORD_RESET_TTL_MIN=30
# Rate limit window per (tenant_id, email) (default 10, min 1, max 120)
CORPFLOW_PASSWORD_RESET_RATE_LIMIT_MIN=10
# For local/system testing only: include reset token in API response (default false). DO NOT enable in prod.
CORPFLOW_PASSWORD_RESET_DEBUG_RETURN_TOKEN=false

# -----------------------------
# ROOT — Automation spine (agents + webhooks)
# -----------------------------
# Ingest secret for POST /api/automation/ingest (header x-corpflow-automation-secret).
# Factory master (session or MASTER_ADMIN_KEY) also works for break-glass.
CORPFLOW_AUTOMATION_INGEST_SECRET=
# Required for high-risk event_type prefixes (billing.*, payment.*, delete.*, …).
# Send header x-corpflow-automation-approval on the same ingest request.
CORPFLOW_AUTOMATION_APPROVAL_SECRET=
# Optional: comma-separated extra high-risk prefixes (lowercase), e.g. "acme.danger.,finance."
CORPFLOW_AUTOMATION_HIGH_RISK_PREFIXES=
# Optional: comma-separated medium-risk prefixes (used for policy / future gating).
CORPFLOW_AUTOMATION_MEDIUM_RISK_PREFIXES=
# Optional: after each accepted event, POST envelope JSON to this URL (e.g. n8n).
CORPFLOW_AUTOMATION_FORWARD_URL=
# Optional: shared secret for forward webhook (header x-corpflow-automation-forward-secret).
CORPFLOW_AUTOMATION_FORWARD_SECRET=
# Mirror CMP lifecycle into automation_events + same forward as ingest (default true). Set false to disable DB writes from CMP.
CORPFLOW_AUTOMATION_CMP_MIRROR=true
# Optional: POST /api/factory/tenant/bootstrap without factory master (header x-corpflow-tenant-bootstrap-secret).
CORPFLOW_TENANT_BOOTSTRAP_SECRET=
# When true, event_type tenant.bootstrap.execute on POST /api/automation/ingest runs full tenant bootstrap (needs ingest secret + payload body).
CORPFLOW_AUTOMATION_TENANT_BOOTSTRAP=false

# -----------------------------
# ROOT — Safe research (allowlisted; off by default)
# -----------------------------
# Factory research fetch is disabled by default. When enabled, only allowlisted HTTPS hosts are allowed.
CORPFLOW_RESEARCH_FETCH_ENABLED=false
# Optional emergency override of allowlist JSON (same shape as config/research-domain-allowlist.v1.json).
CORPFLOW_RESEARCH_DOMAIN_ALLOWLIST_JSON=

# -----------------------------
# ROOT — Ticket monitoring (cron)
# -----------------------------
# Optional: comma-separated CMP ticket IDs to monitor via GET /api/cron/cmp-monitor.
# If unset/empty, the cron falls back to the current priority tickets in code.
CMP_MONITOR_TICKET_IDS=

# Auth backend selection (recommended: postgres)
# - postgres: use Postgres `auth_users` table (Elestio)
# - env: use CORPFLOW_ADMIN_USERNAME/CORPFLOW_ADMIN_PASSWORD
CORPFLOW_AUTH_BACKEND=postgres

# Tenants backend (recommended: postgres)
CORPFLOW_TENANTS_BACKEND=postgres

# CMP storage backend (recommended: postgres)
# - postgres: store tickets + console_json in Postgres (Elestio)
CORPFLOW_CMP_BACKEND=postgres

# -----------------------------
# ROOT — Postgres (Neon, via Prisma ORM)
# -----------------------------
# Provider: Neon (https://neon.tech). All six keys below MUST point at the SAME Neon project.
# NOT Prisma Postgres (db.prisma.io) — that is a different product. See:
#   docs/operations/POSTGRES_PROVIDER.md  (canonical: which key feeds which consumer, rotation, verify)
#
# Pooled URLs (serverless runtime, Prisma Client). Hostname pattern: *-pooler.<region>.aws.neon.tech
# Prisma reads this name from prisma/schema.prisma (datasource.url = env("POSTGRES_URL")).
POSTGRES_URL=
# Generic Node libraries + some Vercel integrations
DATABASE_URL=
# Some Vercel-Prisma integration paths
PRISMA_DATABASE_URL=
# Legacy alias; cfg('POSTGRES_URL') in lib/server/runtime-config.js falls back to this
POSTGRES_PRISMA_URL=
#
# Non-pooling URLs (migrations, build-time DDL, long-running sessions). Same project, no -pooler.
# scripts/apply-ensure-schema-build.mjs prefers POSTGRES_URL_NON_POOLING at build time.
POSTGRES_URL_NON_POOLING=
DIRECT_URL=
#
# GitHub Actions (Agent CI): add the SAME pooled value as repository secret POSTGRES_URL so
# `npx prisma migrate deploy` runs on push/PR to main. UI: Repo → Settings → Secrets and variables
# → Actions → New repository secret. CLI: `gh secret set POSTGRES_URL --body 'postgresql://...'`
# (or paste from Vercel → Project → Settings → Environment Variables).
#
# One-click schema (factory only): POST /api/factory/postgres/ensure-schema
# Auth: admin cookie session OR Bearer MASTER_ADMIN_KEY / x-session-token.
# Creates tenants, auth_users, cmp_tickets if missing (idempotent).

# Session token expected from admin; verify logic compares this to MASTER_ADMIN_KEY.
# Typically set by an admin bootstrap flow and stored client-side.
SESSION_TOKEN=

# WhatsApp number(s) for exec escalation (optional).
EXEC_WHATSAPP_NUMBER=

# -----------------------------
# ROOT — Vercel
# -----------------------------
# GitHub App / deployment signing PEM (required on Vercel for vanguard/notary.js APP signatures).
APP_PRIVATE_KEY=

# Local Node scripts (`scripts/bootstrap-repo-env.mjs`) load `.env` + `.env.local` automatically.
# Prefer VERCEL_TOKEN for API calls from this repo; if only VERCEL_AUTH_TOKEN is set, it is aliased to VERCEL_TOKEN.
# Canonical variable — single source of truth:
VERCEL_TOKEN=
VERCEL_AUTH_TOKEN=
VERCEL_PROJECT_ID=
# Team / org scope for api.vercel.com (use the same project as Git deployments). Either is fine:
VERCEL_TEAM_ID=
VERCEL_ORG_ID=
# Optional: `npm run control:loop -- --execute-hook`
VERCEL_DEPLOY_HOOK_URL=
#
# Factory health URL for Technical Lead observer: site origin OR full .../api/factory/health (both accepted).
# GitHub Actions `factory-health-ping.yml` secret is the full URL only — you may reuse that exact string here on Vercel.
# Example origin: https://corpflowai.com — also set via CORPFLOW_PUBLIC_BASE_URL when health vars are unset.
FACTORY_HEALTH_URL=
CORPFLOW_FACTORY_HEALTH_URL=
#
# GitHub Actions only (Settings → Secrets → Actions) — not read by the app on Vercel:
#   `.github/workflows/domain-routing-guard.yml` — optional; unset = step skipped.
#   CORPFLOW_CORE_BASE_URL           e.g. https://core.corpflowai.com
#   CORPFLOW_APEX_BASE_URL           e.g. https://corpflowai.com (optional)
#   CORPFLOW_TENANT_CLIENT_BASE_URL  e.g. https://lux.corpflowai.com — catches tenant Production 404 while Preview works
#
# Keep VERCEL_TOKEN + VERCEL_PROJECT_ID (+ team id) identical to whatever promote-status / preview lookup uses.
# Preview deployments are matched by Vercel meta `githubCommitRef` === sandbox branch `cmp/{ticketId}` (ticket id
# sanitized the same way as in lib/cmp/_lib/vercel-preview.js: non [A-Za-z0-9._-] → `_`).

# -----------------------------
# Technical Lead observer (optional)
# -----------------------------
# Override default checklist JSON (default: repo config/technical-lead-checklist.v1.json).
CORPFLOW_TECHNICAL_LEAD_CHECKLIST_PATH=
# When true, optional Groq rephrase of the deterministic summary (stored in evidence_json only; GROQ_API_KEY required).
CORPFLOW_TECHNICAL_LEAD_LLM_SUMMARY=false
# Model id for TL rephrase only; empty = built-in default in lib/server/groq-client.js (not GROQ_MODEL_NAME).
CORPFLOW_TECHNICAL_LEAD_LLM_MODEL=

# -----------------------------
# ROOT — Twilio / WhatsApp (optional)
# -----------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ADMIN_WHATSAPP_NUMBER=
WHATSAPP_FROM=whatsapp:+14155238886

# -----------------------------
# ROOT — Sandbox / Code Execution (optional)
# -----------------------------
SANDBOX_TYPE=local
SANDBOX_TIMEOUT_SEC=30
SANDBOX_MAX_OUTPUT_KB=64

MSB_SERVER_URL=http://127.0.0.1:5555
MSB_API_KEY=
MSB_IMAGE=microsandbox/python
MSB_CPU_LIMIT=1.0
MSB_MEMORY_MB=512
MSB_START_TIMEOUT_SEC=30

# -----------------------------
# ROOT — External glue tooling (optional)
# -----------------------------
# Used by `sync_conductor.py` to poll a Google Apps Script endpoint.
GOOGLE_SCRIPT_URL=

# -----------------------------
# ROOT — Ethical Sentinel / Budget Gate
# -----------------------------
# Hard cap for cost_estimate/full_market_value_usd used by verify-rigor.
# If exceeded, build is rejected and a high-cost telemetry event is emitted.
HARD_BUDGET_CAP_USD=25000
#
# Vanguard execution on serverless (e.g. Vercel has no `python` on PATH):
#   auto — try Python, fall back to Node heuristic (default)
#   node — Node only (budget + same keyword/length heuristic as verify-rigor.py)
#   python — Python-only (fails if python missing)
#   off  — bypass ethical scoring only; HARD_BUDGET_CAP_USD still enforced (avoid in prod)
CORPFLOW_VANGUARD_MODE=auto

# -----------------------------
# ROOT — Overseer (async audit)
# -----------------------------
# How many tickets each overseer sweep processes (Approved+Build, most recently updated first).
OVERSEER_SWEEP_LIMIT=10

# Vercel Cron authentication (recommended).
# Vercel supports sending `Authorization: Bearer <CRON_SECRET>` automatically for cron invocations.
# This app accepts either `CRON_SECRET` or `CORPFLOW_CRON_SECRET`.
CRON_SECRET=
CORPFLOW_CRON_SECRET=

# GitHub Actions — scheduled factory CMP drive (`.github/workflows/factory-cmp-drive.yml`).
# Same Bearer value as CORPFLOW_CRON_SECRET above. Set only as **GitHub repo secrets**, not required in Vercel:
#   CORPFLOW_CORE_BASE_URL            e.g. https://core.corpflowai.com
#   CORPFLOW_CRON_SECRET              must match Production Vercel CORPFLOW_CRON_SECRET / CRON_SECRET
#   CMP_FACTORY_DRIVE_TICKET_IDS      comma-separated CMP ticket ids to refresh/repair (max 25)

# Optional: GitHub Actions (workflow cmp-branch.yml) POSTs PR metadata to your deployed API after
# the sandbox branch + PR exist. This does NOT run during Vercel build — it cannot block deploys.
#
# Vercel (or host) env — required only if you use the callback:
#   CMP_AUTOMATION_CALLBACK_SECRET   shared secret; must exactly match GitHub repo secret of the same name
#
# GitHub repo secrets (Settings → Secrets) — not Vercel:
#   CMP_AUTOMATION_CALLBACK_URL      e.g. https://corpflowai.com/api/cmp/automation-callback
#   CMP_AUTOMATION_CALLBACK_SECRET   same string as Vercel CMP_AUTOMATION_CALLBACK_SECRET
#
# If the secret differs: callback returns 401; branch/PR still succeed; Change Console may miss PR link
# until Refresh promotion / another sync. Do not set CMP_AUTOMATION_CALLBACK_URL on Vercel — the app
# never reads it (URL is only used in GitHub Actions).
CMP_AUTOMATION_CALLBACK_SECRET=

# HMAC secret for signed `cf_preview=` on tenant marketing homepage (`/`).
# When set, Vercel preview URLs can show the correct tenant site without a tenant_hostnames row for `*.vercel.app`.
# Change Console stores `client_view.automation.client_site_preview_url` (share with clients). Generate a long random string.
# **Required on both Production and Preview** Vercel env: verification runs on the deployment that serves the preview URL.
CORPFLOW_TENANT_PREVIEW_SECRET=

# When true, `GET /api/tenant/site?cf_debug=1` may include `tenant_resolution` (host, token presence, verify outcome).
# Use only while diagnosing preview hostname issues; keep false in production unless you accept the extra leakage surface.
CORPFLOW_TENANT_SITE_DEBUG=false

# Optional: Vercel Deployment Protection — append bypass query params to `client_site_preview_url` for `*.vercel.app` only.
# In Vercel: Project → Settings → Deployment Protection → Protection bypass for automation → Add secret.
# Vercel then injects VERCEL_AUTOMATION_BYPASS_SECRET into deployments (system env). No manual copy needed on Vercel.
# For local/scripts signing URLs: paste the same bypass value here, or set CORPFLOW_VERCEL_PROTECTION_BYPASS_SECRET.
VERCEL_AUTOMATION_BYPASS_SECRET=
CORPFLOW_VERCEL_PROTECTION_BYPASS_SECRET=

