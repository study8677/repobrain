generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Lead {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  name      String
  email     String
  phone     String?  @map("phone")
  intent    String
  market    String?  @map("market")
  listing   String?  @map("listing")
  status    String   @default("NEW")
  qualificationJson Json? @map("qualification_json")
  score      String? @map("score")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("leads")
}

model Tenant {
  id               String  @id @default(cuid())
  tenantId         String  @unique @map("tenant_id")
  slug             String  @unique
  name             String
  fqdn             String?
  lifecycle        String? @default("Build")
  tenantStatus     String? @default("Active") @map("tenant_status")
  executionOnly    Boolean @default(false) @map("execution_only")
  sovereignPinHash String? @map("sovereign_pin_hash")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

model AuthUser {
  id           String  @id @default(cuid())
  username     String  @unique
  passwordHash String  @map("password_hash")
  passwordSalt String  @map("password_salt")
  level        String
  tenantId     String? @map("tenant_id")
  enabled      Boolean @default(true)

  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  @@index([level])
  @@index([tenantId])
  @@map("auth_users")
}

model CmpTicket {
  id          String  @id @default(cuid())
  tenantId    String? @map("tenant_id")
  description String?
  status      String? @default("Open")
  stage       String? @default("Intake")
  title       String?
  brief       String?
  locale      String?
  consoleJson Json?   @map("console_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attachments         CmpTicketAttachment[]
  technicalLeadAudits TechnicalLeadAudit[]

  @@index([tenantId])
  @@index([status])
  @@index([stage])
  @@map("cmp_tickets")
}

/// Phase A Technical Lead (Lead Observer): append-only evidence + gaps per ticket scan cycle.
model TechnicalLeadAudit {
  id               String   @id @default(cuid())
  ticketId         String   @map("ticket_id")
  checklistVersion String   @default("v1") @map("checklist_version")
  evidenceJson     Json     @map("evidence_json")
  gapsJson         Json     @map("gaps_json")
  summaryText      String   @map("summary_text")
  createdAt        DateTime @default(now()) @map("created_at")

  ticket CmpTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
  @@map("technical_lead_audits")
}

/// Binary files for Change Console (images / short video / PDF). Served only to ticket-scoped sessions.
model CmpTicketAttachment {
  id          String  @id @default(cuid())
  ticketId    String  @map("ticket_id")
  tenantId    String? @map("tenant_id")
  fileName    String  @map("file_name")
  contentType String  @map("content_type")
  byteSize    Int     @map("byte_size")
  data        Bytes

  createdAt DateTime @default(now()) @map("created_at")

  ticket CmpTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("cmp_ticket_attachments")
}

model TenantPersona {
  id                    String  @id @default(cuid())
  tenantId              String  @unique @map("tenant_id")
  tokenCreditBalanceUsd Float   @default(0) @map("token_credit_balance_usd")
  /// When true, skip token pre-check and debit on approve-build (same effect as env override).
  billingExempt         Boolean @default(false) @map("billing_exempt")
  autonomyLevel         Int?    @map("autonomy_level")
  currentRank           String? @map("current_rank")
  personaJson           Json?   @map("persona_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("tenant_personas")
}

model TokenDebit {
  id             String   @id @default(cuid())
  occurredAt     DateTime @default(now()) @map("occurred_at")
  tenantId       String   @map("tenant_id")
  debitUsd       Float    @map("debit_usd")
  invoiceUsd     Float?   @map("invoice_usd")
  prevBalanceUsd Float?   @map("prev_balance_usd")
  nextBalanceUsd Float?   @map("next_balance_usd")
  context        Json?    @map("context_json")

  @@index([tenantId])
  @@index([occurredAt])
  @@map("token_debits")
}

model TelemetryEvent {
  id          String   @id @default(cuid())
  occurredAt  DateTime @default(now()) @map("occurred_at")
  tenantId    String?  @map("tenant_id")
  factoryId   String?  @map("factory_id")
  eventType   String   @map("event_type")
  cmpTicketId String?  @map("cmp_ticket_id")
  cmpAction   String?  @map("cmp_action")
  payload     Json?    @map("payload_json")

  @@index([tenantId])
  @@index([eventType])
  @@index([occurredAt])
  @@map("telemetry_events")
}

model RecoveryVaultEntry {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now()) @map("occurred_at")
  category   String?  @map("category")
  payload    Json?    @map("payload_json")
  status     String?  @default("PENDING_SYNC")

  @@index([occurredAt])
  @@index([status])
  @@map("recovery_vault_entries")
}

model TenantHostname {
  id       String  @id @default(cuid())
  host     String  @unique
  tenantId String  @map("tenant_id")
  mode     String? @map("mode")
  enabled  Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([enabled])
  @@map("tenant_hostnames")
}

/// Append-only automation spine: agents and webhooks post here first.
model AutomationEvent {
  id             String   @id @default(cuid())
  occurredAt     DateTime @default(now()) @map("occurred_at")
  tenantId       String?  @map("tenant_id")
  tenantScope    String   @map("tenant_scope")
  source         String?  @default("ingest")
  eventType      String   @map("event_type")
  correlationId  String?  @map("correlation_id")
  idempotencyKey String?  @map("idempotency_key")
  riskTier       String   @default("low") @map("risk_tier")
  status         String   @default("accepted")
  payload        Json?    @map("payload_json")

  @@unique([tenantScope, idempotencyKey], name: "automation_events_scope_idem")
  @@index([tenantId])
  @@index([tenantScope])
  @@index([eventType])
  @@index([occurredAt])
  @@map("automation_events")
}

/// Curated playbooks for agents (integration patterns, runbooks).
model AutomationPlaybook {
  id          String   @id @default(cuid())
  tenantScope String   @map("tenant_scope")
  slug        String
  title       String
  bodyMd      String   @map("body_md")
  tags        Json?    @map("tags_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantScope, slug])
  @@index([tenantScope])
  @@map("automation_playbooks")
}

/// Tenant-scoped outbound / ABM pipeline (segments → companies → contacts → touchpoints).
model GrowthSegment {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  slug         String
  name         String
  thesisMd     String   @default("") @map("thesis_md")
  regionTags   String?  @map("region_tags")
  industryTags String?  @map("industry_tags")
  priority     Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companies GrowthCompany[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("growth_segments")
}

model GrowthCompany {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  segmentId String?  @map("segment_id")
  name      String
  website   String?
  country   String?
  notes     String?
  status    String   @default("research")
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  segment  GrowthSegment?  @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  contacts GrowthContact[]

  @@index([tenantId])
  @@index([segmentId])
  @@map("growth_companies")
}

model GrowthContact {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  companyId    String   @map("company_id")
  fullName     String   @map("full_name")
  roleTitle    String?  @map("role_title")
  email        String?
  linkedinUrl  String?  @map("linkedin_url")
  notes        String?
  consentBasis String?  @map("consent_basis")
  status       String   @default("identified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company     GrowthCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  touchpoints GrowthTouchpoint[]

  @@index([tenantId])
  @@index([companyId])
  @@map("growth_contacts")
}

model GrowthTouchpoint {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  contactId   String    @map("contact_id")
  channel     String
  subject     String?
  bodyMd      String    @default("") @map("body_md")
  stage       String    @default("awareness")
  scheduledAt DateTime? @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  contact GrowthContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([contactId])
  @@map("growth_touchpoints")
}
