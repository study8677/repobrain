generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Lead {
  id                String   @id @default(cuid())
  tenantId          String?  @map("tenant_id")
  name              String
  email             String
  contact           String?  @map("contact")
  message           String?  @map("message")
  phone             String?  @map("phone")
  intent            String
  market            String?  @map("market")
  listing           String?  @map("listing")
  status            String   @default("NEW")
  qualificationJson Json?    @map("qualification_json")
  score             String?  @map("score")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("leads")
}

model Tenant {
  id               String  @id @default(cuid())
  tenantId         String  @unique @map("tenant_id")
  slug             String  @unique
  name             String
  fqdn             String?
  lifecycle        String? @default("Build")
  tenantStatus     String? @default("Active") @map("tenant_status")
  executionOnly    Boolean @default(false) @map("execution_only")
  sovereignPinHash String? @map("sovereign_pin_hash")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

model AuthUser {
  id            String  @id @default(cuid())
  username      String  @unique
  passwordHash  String  @map("password_hash")
  passwordSalt  String  @map("password_salt")
  level         String
  tenantId      String? @map("tenant_id")
  enabled       Boolean @default(true)
  /// IM-1: blanket cross-tenant access capability for operators only. See
  /// docs/operations/OPERATOR_MULTI_TENANT_CREDENTIAL_V1.md §2.6. DB CHECK
  /// constraint (auth_users_factory_master_admin_only) enforces level='admin'
  /// when true; no application code reads this column in IM-1.
  factoryMaster Boolean @default(false) @map("factory_master")

  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  @@index([level])
  @@index([tenantId])
  @@map("auth_users")
}

model CmpTicket {
  id          String  @id @default(cuid())
  tenantId    String? @map("tenant_id")
  description String?
  status      String? @default("Open")
  stage       String? @default("Intake")
  title       String?
  brief       String?
  locale      String?
  consoleJson Json?   @map("console_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attachments         CmpTicketAttachment[]
  technicalLeadAudits TechnicalLeadAudit[]

  @@index([tenantId])
  @@index([status])
  @@index([stage])
  @@map("cmp_tickets")
}

/// Phase A Technical Lead (Lead Observer): append-only evidence + gaps per ticket scan cycle.
model TechnicalLeadAudit {
  id               String   @id @default(cuid())
  ticketId         String   @map("ticket_id")
  checklistVersion String   @default("v1") @map("checklist_version")
  evidenceJson     Json     @map("evidence_json")
  gapsJson         Json     @map("gaps_json")
  summaryText      String   @map("summary_text")
  createdAt        DateTime @default(now()) @map("created_at")

  ticket CmpTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
  @@map("technical_lead_audits")
}

/// Binary files for Change Console (images / short video / PDF). Served only to ticket-scoped sessions.
model CmpTicketAttachment {
  id          String  @id @default(cuid())
  ticketId    String  @map("ticket_id")
  tenantId    String? @map("tenant_id")
  fileName    String  @map("file_name")
  contentType String  @map("content_type")
  byteSize    Int     @map("byte_size")
  data        Bytes

  createdAt DateTime @default(now()) @map("created_at")

  ticket CmpTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("cmp_ticket_attachments")
}

/// Manual LuxeMaurice catalogue rows (Phase 2). Public HTTP reads return only `visibility_status = published` on Lux host.
model LuxListing {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  slug             String
  title            String
  regionLabel      String    @map("region_label")
  propertyType     String    @map("property_type")
  listingStatus    String?   @map("listing_status")
  priceRange       String?   @map("price_range")
  shortTeaser      String?   @map("short_teaser")
  description      String    @default("")
  highlightsJson   Json      @default("[]") @map("highlights_json")
  bedrooms         Int?
  bathrooms        Float?
  areaSqm          Float?    @map("area_sqm")
  mediaRefsJson    Json?     @map("media_refs_json")
  visibilityStatus String    @map("visibility_status")
  createdById      String?   @map("created_by_id")
  updatedById      String?   @map("updated_by_id")
  publishedAt      DateTime? @map("published_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, slug], map: "lux_listings_tenant_id_slug_key")
  @@index([tenantId, visibilityStatus], map: "lux_listings_tenant_id_visibility_status_idx")
  @@map("lux_listings")
}

model TenantPersona {
  id                    String  @id @default(cuid())
  tenantId              String  @unique @map("tenant_id")
  tokenCreditBalanceUsd Float   @default(0) @map("token_credit_balance_usd")
  /// When true, skip token pre-check and debit on approve-build (same effect as env override).
  billingExempt         Boolean @default(false) @map("billing_exempt")
  autonomyLevel         Int?    @map("autonomy_level")
  currentRank           String? @map("current_rank")
  personaJson           Json?   @map("persona_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("tenant_personas")
}

model TokenDebit {
  id             String   @id @default(cuid())
  occurredAt     DateTime @default(now()) @map("occurred_at")
  tenantId       String   @map("tenant_id")
  debitUsd       Float    @map("debit_usd")
  invoiceUsd     Float?   @map("invoice_usd")
  prevBalanceUsd Float?   @map("prev_balance_usd")
  nextBalanceUsd Float?   @map("next_balance_usd")
  context        Json?    @map("context_json")

  @@index([tenantId])
  @@index([occurredAt])
  @@map("token_debits")
}

model TelemetryEvent {
  id          String   @id @default(cuid())
  occurredAt  DateTime @default(now()) @map("occurred_at")
  tenantId    String?  @map("tenant_id")
  factoryId   String?  @map("factory_id")
  eventType   String   @map("event_type")
  cmpTicketId String?  @map("cmp_ticket_id")
  cmpAction   String?  @map("cmp_action")
  payload     Json?    @map("payload_json")
  /// IM-1: audit identity of the user who caused this event (auth_users.id).
  /// Nullable for backfill safety; new operator-mediated writes populate it in IM-7.
  actorUserId String?  @map("actor_user_id")

  @@index([tenantId])
  @@index([eventType])
  @@index([occurredAt])
  @@index([actorUserId])
  @@map("telemetry_events")
}

model RecoveryVaultEntry {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now()) @map("occurred_at")
  category   String?  @map("category")
  payload    Json?    @map("payload_json")
  status     String?  @default("PENDING_SYNC")

  @@index([occurredAt])
  @@index([status])
  @@map("recovery_vault_entries")
}

model TenantHostname {
  id       String  @id @default(cuid())
  host     String  @unique
  tenantId String  @map("tenant_id")
  mode     String? @map("mode")
  enabled  Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([enabled])
  @@map("tenant_hostnames")
}

/// IM-1 (2026-06-15) — Multi-tenant user membership matrix.
/// One row grants `user_id` the right to act inside `tenant_id`. Soft-revocation
/// via `revoked_at`; partial unique index on `(user_id, tenant_id) WHERE revoked_at IS NULL`
/// is enforced at the DB level (Prisma cannot express partial indexes in this schema;
/// see lib/server/postgres-ensure-schema-statements.js and the IM-1 migration).
/// No production code reads this table in IM-1; the helper getEffectiveMemberships(user_id)
/// arrives in IM-2.
/// Canonical spec: docs/operations/OPERATOR_MULTI_TENANT_CREDENTIAL_V1.md §2.3.
model UserTenantMembership {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tenantId   String    @map("tenant_id")
  role       String    @default("member")
  capability String?
  enabled    Boolean   @default(true)
  grantedAt  DateTime  @default(now()) @map("granted_at")
  /// `'system'` for IM-1 back-fill rows; auth_users.id for manual grants.
  grantedBy  String    @default("system") @map("granted_by")
  revokedAt  DateTime? @map("revoked_at")
  disabledAt DateTime? @map("disabled_at")
  notes      String?

  @@index([userId])
  @@index([tenantId])
  @@index([userId, enabled, revokedAt], name: "user_tenant_memberships_user_enabled_revoked_idx")
  @@map("user_tenant_memberships")
}

/// Append-only automation spine: agents and webhooks post here first.
model AutomationEvent {
  id             String   @id @default(cuid())
  occurredAt     DateTime @default(now()) @map("occurred_at")
  tenantId       String?  @map("tenant_id")
  tenantScope    String   @map("tenant_scope")
  source         String?  @default("ingest")
  eventType      String   @map("event_type")
  correlationId  String?  @map("correlation_id")
  idempotencyKey String?  @map("idempotency_key")
  riskTier       String   @default("low") @map("risk_tier")
  status         String   @default("accepted")
  payload        Json?    @map("payload_json")
  /// IM-1: audit identity of the user who caused this event (auth_users.id).
  /// Nullable for backfill safety; new operator-mediated writes populate it in IM-7.
  actorUserId    String?  @map("actor_user_id")

  @@unique([tenantScope, idempotencyKey], name: "automation_events_scope_idem")
  @@index([tenantId])
  @@index([tenantScope])
  @@index([eventType])
  @@index([occurredAt])
  @@index([actorUserId])
  @@map("automation_events")
}

/// Curated playbooks for agents (integration patterns, runbooks).
model AutomationPlaybook {
  id          String   @id @default(cuid())
  tenantScope String   @map("tenant_scope")
  slug        String
  title       String
  bodyMd      String   @map("body_md")
  tags        Json?    @map("tags_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantScope, slug])
  @@index([tenantScope])
  @@map("automation_playbooks")
}

/// Tenant-scoped outbound / ABM pipeline (segments → companies → contacts → touchpoints).
model GrowthSegment {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  slug         String
  name         String
  thesisMd     String   @default("") @map("thesis_md")
  regionTags   String?  @map("region_tags")
  industryTags String?  @map("industry_tags")
  priority     Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companies GrowthCompany[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("growth_segments")
}

model GrowthCompany {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  segmentId String?  @map("segment_id")
  name      String
  website   String?
  country   String?
  notes     String?
  status    String   @default("research")
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  segment  GrowthSegment?  @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  contacts GrowthContact[]

  @@index([tenantId])
  @@index([segmentId])
  @@map("growth_companies")
}

model GrowthContact {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  companyId    String   @map("company_id")
  fullName     String   @map("full_name")
  roleTitle    String?  @map("role_title")
  email        String?
  linkedinUrl  String?  @map("linkedin_url")
  notes        String?
  consentBasis String?  @map("consent_basis")
  status       String   @default("identified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company     GrowthCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  touchpoints GrowthTouchpoint[]

  @@index([tenantId])
  @@index([companyId])
  @@map("growth_contacts")
}

model GrowthTouchpoint {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  contactId   String    @map("contact_id")
  channel     String
  subject     String?
  bodyMd      String    @default("") @map("body_md")
  stage       String    @default("awareness")
  scheduledAt DateTime? @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  contact GrowthContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([contactId])
  @@map("growth_touchpoints")
}

/// Chat Widget v0 — per-tenant configuration for the embeddable text-only chatbot.
/// Anonymous-public widget; no operator session at runtime. Tenant resolved from host
/// via `tenant_hostnames`. Kill switch is `enabled` field; AI columns are placeholders
/// for a future tier (no LLM call in v0).
model ChatWidgetConfig {
  id                     String   @id @default(cuid())
  tenantId               String   @unique @map("tenant_id")
  enabled                Boolean  @default(false)
  brandName              String   @map("brand_name")
  brandAccent            String?  @map("brand_accent")
  brandLogoUrl           String?  @map("brand_logo_url")
  greeting               String   @default("Hi! How can we help today?")
  flowJson               Json     @map("flow_json")
  flowVersion            Int      @default(1) @map("flow_version")
  notifyVia              String   @default("automation_event") @map("notify_via")
  notifyEmail            String?  @map("notify_email")
  allowedOrigins         Json     @default("[]") @map("allowed_origins_json")
  rateLimitPerWindow     Int      @default(30) @map("rate_limit_per_window")
  rateLimitWindowSeconds Int      @default(300) @map("rate_limit_window_seconds")
  aiBudgetMonthlyUsd     Float    @default(0) @map("ai_budget_monthly_usd")
  aiBudgetSpentUsd       Float    @default(0) @map("ai_budget_spent_usd")
  aiBudgetMonthYyyymm    String?  @map("ai_budget_month_yyyymm")
  messagesThisMonth      Int      @default(0) @map("messages_this_month")
  messagesMonthYyyymm    String?  @map("messages_month_yyyymm")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("chat_widget_configs")
}

/// Chat Widget v0 — one row per visitor session. Lead snapshot fields populate as
/// the flow advances. Status: active | completed | abandoned. Notification status
/// recorded so retries / observability are possible later.
model ChatWidgetThread {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  sourceHost  String?   @map("source_host")
  sourcePath  String?   @map("source_path")
  ipHash      String?   @map("ip_hash")
  userAgent   String?   @map("user_agent")
  leadName    String?   @map("lead_name")
  leadEmail   String?   @map("lead_email")
  leadPhone   String?   @map("lead_phone")
  requestType String?   @map("request_type")
  leadMessage String?   @map("lead_message")
  status      String    @default("active")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  ticketId    String?   @map("ticket_id")
  notifiedAt  DateTime? @map("notified_at")
  notifyError String?   @map("notify_error")
  flowVersion Int       @default(1) @map("flow_version")
  currentNode String?   @map("current_node")

  messages ChatWidgetMessage[]

  @@index([tenantId, startedAt])
  @@index([tenantId, status])
  @@map("chat_widget_threads")
}

/// Chat Widget v0 — one row per step (bot prompt or user response).
model ChatWidgetMessage {
  id        String   @id @default(cuid())
  threadId  String   @map("thread_id")
  tenantId  String   @map("tenant_id")
  direction String
  nodeId    String?  @map("node_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  thread ChatWidgetThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([tenantId, createdAt])
  @@map("chat_widget_messages")
}

/// Chat Widget v0 — sliding-window rate limiter rows. One row per
/// (tenant, ip_hash, window_start_minute). Pruned by app logic on write
/// (rows older than 24h dropped opportunistically).
model ChatWidgetRateLimit {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  ipHash      String   @map("ip_hash")
  windowStart DateTime @map("window_start")
  count       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([tenantId, ipHash, windowStart], name: "chat_widget_rate_limits_t_ip_w")
  @@index([tenantId, ipHash])
  @@index([windowStart])
  @@map("chat_widget_rate_limits")
}
